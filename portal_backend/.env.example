APP_NAME=Web3Bridge Student Portal API
APP_ENV=development
API_V1_PREFIX=/api/v1
DEBUG=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=portal_v1
POSTGRES_USER=portal_user
POSTGRES_PASSWORD=portal_password
POSTGRES_SCHEMA=portal

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SYNC_WORKER_ERROR_RETRY_BASE_SECONDS=1
SYNC_WORKER_ERROR_RETRY_MAX_SECONDS=30

JWT_SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=90

INTERNAL_API_KEY=change-me-internal-key
PORTAL_FRONTEND_URL=http://localhost:3000

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=support@web3bridge.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=support@web3bridge.com
ADMISSION_EMAIL_HOST_USER=admission@web3bridge.com
